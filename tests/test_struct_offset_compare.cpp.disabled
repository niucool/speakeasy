// ═══════════════════════════════════════════════════════════════
// CONTEXT (x86) — size-only check, layout differs from x64
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, CONTEXT_x86) {
    EXPECT_EQ(ns::CONTEXT().sizeof_obj(), 204);  // x86 CONTEXT is always 204
    EXPECT_EQ(ns::CONTEXT64().sizeof_obj(), 1144);  // x64 minimal CONTEXT
}

// ═══════════════════════════════════════════════════════════════
// EXCEPTION_RECORD
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, EXCEPTION_RECORD) {
    auto win_sz = sizeof(::EXCEPTION_RECORD);
    auto our_sz = ns::EXCEPTION_RECORD<sizeof(void*)>().sizeof_obj();
    CHECK_SIZE("EXCEPTION_RECORD", our_sz, win_sz);
}
