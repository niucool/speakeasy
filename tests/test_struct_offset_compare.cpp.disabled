#pragma pop_macro("PagedPool")
#pragma pop_macro("FILE_ATTRIBUTE_READONLY")
#pragma pop_macro("FILE_ATTRIBUTE_HIDDEN")
#pragma pop_macro("FILE_ATTRIBUTE_DIRECTORY")
#pragma pop_macro("FILE_ATTRIBUTE_NORMAL")

// ── Windows SDK ───────────────────────────────────────────────
#define WIN32_LEAN_AND_MEAN
#define _WIN32_WINNT 0x0601
#include <windows.h>
#include <tlhelp32.h>
#include <winternl.h>
#include <winuser.h>
#include <winbase.h>
#include <winnt.h>
#include <ws2def.h>
#include <winsock2.h>
#include <ws2tcpip.h>
#include <iphlpapi.h>
#include <shellapi.h>
#include <winreg.h>
#include <wininet.h>
#include <lmwksta.h>

namespace ns = speakeasy::deffs;

// ── Helpers ───────────────────────────────────────────────────
#define CHECK_SIZE(struct_name, our_sz, win_sz) \
    EXPECT_EQ((our_sz), (win_sz)) \
        << "  " << struct_name << ": our=" << (our_sz) << " win=" << (win_sz)

// Field diagnostic: prints our field offset vs Windows SDK offset.
// Does NOT assert equality — just outputs the values for debugging.
// pack(1) structs will naturally have different offsets than native-aligned SDK.
#define DIAG_FIELD(struct_name, field, our_type, win_type, our_pod, win_sdk) \
    do { \
        auto o = offsetof(our_pod, field); \
        auto w = offsetof(win_sdk, field); \
        auto os = sizeof(our_type); \
        auto ws = sizeof(win_type); \
        std::cout << "  " << struct_name << "::" << #field \
                  << ": our_offset=" << o << " win_offset=" << w \
                  << " our_size=" << os << " win_size=" << ws; \
        if (o != w) std::cout << " *** DIFF (pack(1) vs natural alignment)"; \
        std::cout << std::endl; \
    } while(0)

// ═══════════════════════════════════════════════════════════════
// MEMORY_BASIC_INFORMATION — SIZE ONLY (pack(1) offsets differ)
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, MEMORY_BASIC_INFORMATION) {
    size_t win_sz = sizeof(::MEMORY_BASIC_INFORMATION);
    size_t our_sz = ns::MEMORY_BASIC_INFORMATION<sizeof(void*)>().sizeof_obj();
    CHECK_SIZE("MEMORY_BASIC_INFORMATION", our_sz, win_sz);

    DIAG_FIELD("MBI", BaseAddress, void*, void*,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", AllocationBase, void*, void*,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", AllocationProtect, uint32_t, DWORD,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", RegionSize, void*, void*,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", State, uint32_t, DWORD,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", Protect, uint32_t, DWORD,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
    DIAG_FIELD("MBI", Type, uint32_t, DWORD,
        ns::MEMORY_BASIC_INFORMATION_POD<sizeof(void*)>, ::MEMORY_BASIC_INFORMATION);
}

// ═══════════════════════════════════════════════════════════════
// OSVERSIONINFOEX
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, OSVERSIONINFOEX) {
    auto win_sz = sizeof(::OSVERSIONINFOEX);
    auto our_sz = ns::OSVERSIONINFOEX().sizeof_obj();
    CHECK_SIZE("OSVERSIONINFOEX", our_sz, win_sz);

    DIAG_FIELD("OSVINFOEX", dwOSVersionInfoSize, uint32_t, DWORD,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", dwMajorVersion, uint32_t, DWORD,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", dwBuildNumber, uint32_t, DWORD,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", szCSDVersion, uint8_t[128], CHAR[128],
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", wServicePackMajor, uint16_t, WORD,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", wSuiteMask, uint16_t, WORD,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
    DIAG_FIELD("OSVINFOEX", wProductType, uint8_t, BYTE,
        ns::OSVERSIONINFOEX_POD, ::OSVERSIONINFOEX);
}

// ═══════════════════════════════════════════════════════════════
// WNDCLASSEX
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, WNDCLASSEX) {
    ::WNDCLASSEX wc_win;
    auto win_sz = sizeof(wc_win);
    auto our_sz = ns::WNDCLASSEX<sizeof(void*)>().sizeof_obj();
    CHECK_SIZE("WNDCLASSEX", our_sz, win_sz);
}

// ═══════════════════════════════════════════════════════════════
// WSAData
// ═══════════════════════════════════════════════════════════════

TEST(OffsetCompare, WSAData) {
    auto win_sz = sizeof(::WSADATA);
    auto our_sz = ns::WSAData<sizeof(void*)>().sizeof_obj();
    CHECK_SIZE("WSAData", our_sz, win_sz);

    DIAG_FIELD("WSAData", wVersion, uint16_t, WORD,
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", wHighVersion, uint16_t, WORD,
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", szDescription, uint8_t[257], CHAR[257],
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", szSystemStatus, uint8_t[129], CHAR[129],
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", iMaxSockets, uint16_t, WORD,
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", iMaxUdpDg, uint16_t, WORD,
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
    DIAG_FIELD("WSAData", lpVendorInfo, void*, char*,
        ns::WSAData_POD<sizeof(void*)>, ::WSADATA);
}

